{
  "name": "astro",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "lint": "vp lint --fix",
    "lint:md": "markdownlint-cli2 --fix",
    "style:lint": "stylelint --fix './src/**/*.css' './**/snippets/CSS/**/*.css'",
    "format": "vp fmt --write",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "typecheck:tsgo": "tsgo --noEmit --skipLibCheck",
    "check": "vp run lint:md && vp run lint && vp run format && vp run astro:check && vp run style:lint",
    "spell:check": "cspell lint --no-progress --show-context --relative .",
    "prepare": "vp config",
    "update:edit:date": "node --experimental-strip-types scripts/update-frontmatter.ts",
    "reset": "rm -rf node_modules pnpm-lock.yaml && vp install"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/starlight": "^0.38.2",
    "@catppuccin/starlight": "^2.0.1",
    "@types/node": "^25.0.9",
    "astro": "^6.0.8",
    "astro-embed": "^0.12.0",
    "astro-og-canvas": "^0.10.0",
    "canvaskit-wasm": "^0.41.0",
    "sharp": "^0.34.5",
    "starlight-blog": "^0.26.1",
    "starlight-kbd": "^0.4.0",
    "starlight-links-validator": "^0.20.1",
    "starlight-package-managers": "^0.12.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "cspell": "^9.6.0",
    "markdownlint-cli2": "^0.22.0",
    "markdownlint-cli2-formatter-pretty": "^0.0.10",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.8.0",
    "stylelint-use-logical-spec": "^5.0.1",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.17.1"
}
