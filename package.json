{
  "name": "astro",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "vp run lint:md && vp run lint && vp run format && vp run astro:check && vp run style:lint && vp run spell:check",
    "dev": "astro dev",
    "format": "vp fmt --write",
    "knip": "knip",
    "lint:md": "markdownlint-cli2 --fix",
    "lint": "vp lint --fix",
    "prepare": "vp config",
    "preview": "astro preview",
    "reset": "rm -rf node_modules pnpm-lock.yaml && vp install",
    "spell:check": "cspell lint --no-progress --show-context --relative .",
    "start": "astro dev",
    "style:lint": "stylelint --fix './src/**/*.css' './**/snippets/CSS/**/*.css'",
    "typecheck:tsgo": "tsgo --noEmit --skipLibCheck",
    "typecheck": "astro check",
    "update:edit:date": "node --experimental-strip-types scripts/update-frontmatter.ts"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.38.3",
    "@catppuccin/starlight": "^2.0.1",
    "@types/node": "^25.5.2",
    "astro": "^6.1.4",
    "astro-embed": "^0.12.0",
    "astro-og-canvas": "^0.11.0",
    "canvaskit-wasm": "^0.41.1",
    "starlight-blog": "^0.26.1",
    "starlight-kbd": "^0.4.0",
    "starlight-links-validator": "^0.22.0",
    "starlight-package-managers": "^0.12.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260408.1",
    "cspell": "^10.0.0",
    "knip": "^6.3.1",
    "markdownlint-cli2": "^0.22.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.8.1",
    "stylelint-use-logical-spec": "^5.0.1",
    "typescript": "^6.0.2",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.17.1"
}
