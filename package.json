{
  "name": "astro",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "lint": "oxlint --fix .",
    "lint:md": "markdownlint-cli2 --fix",
    "style:lint": "stylelint --cache --fix './src/**/*.css' './**/snippets/CSS/**/*.css'",
    "format": "oxfmt --write",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "typecheck:tsgo": "tsgo --noEmit --skipLibCheck",
    "check": "pnpm lint:md && pnpm lint && pnpm format && pnpm typecheck && pnpm typecheck:tsgo && pnpm style:lint",
    "spell:check": "cspell lint --no-progress --show-context --relative .",
    "prepare": "husky",
    "update:edit:date": "node --experimental-strip-types scripts/update-frontmatter.ts",
    "reset": "rm -rf node_modules pnpm-lock.yaml && pnpm install"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/starlight": "^0.37.6",
    "@catppuccin/starlight": "^1.0.2",
    "@types/node": "^25.0.9",
    "astro": "^5.17.2",
    "astro-embed": "^0.12.0",
    "astro-og-canvas": "^0.10.0",
    "canvaskit-wasm": "^0.40.0",
    "sharp": "^0.34.5",
    "starlight-blog": "^0.25.2",
    "starlight-kbd": "^0.3.0",
    "starlight-links-validator": "^0.19.2",
    "starlight-package-managers": "^0.12.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "cspell": "^9.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.20.0",
    "markdownlint-cli2-formatter-pretty": "^0.0.9",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.2",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-plugin-defensive-css": "^1.0.2",
    "stylelint-use-logical-spec": "^5.0.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.17.1"
}
