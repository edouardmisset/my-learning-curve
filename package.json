{
  "name": "astro",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "vp run lint:md && vp run lint && vp run format && vp run astro:check && vp run style:lint && vp run spell:check",
    "dev": "astro dev",
    "format": "vp fmt --write",
    "knip": "knip",
    "lint:md": "markdownlint-cli2 \"**/*.{md,mdx}\" --fix",
    "lint": "vp lint --fix --no-error-on-unmatched-pattern",
    "prepare": "vp config",
    "preview": "astro preview",
    "reset": "rm -rf node_modules pnpm-lock.yaml && vp install",
    "spell:check": "cspell lint --no-progress --show-context --relative .",
    "style:lint": "stylelint --fix './src/**/*.css' './**/snippets/CSS/**/*.css'",
    "typecheck:tsgo": "tsgo --noEmit --skipLibCheck",
    "typecheck": "astro check",
    "update:edit:date": "node --experimental-strip-types scripts/update-frontmatter.ts"
  },
  "dependencies": {
    "@ascorbic/feed-loader": "^2.0.1",
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.1",
    "@catppuccin/starlight": "^2.0.1",
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@types/node": "^26.0.1",
    "astro": "^7.0.3",
    "astro-embed": "^0.13.0",
    "astro-mermaid": "^2.1.0",
    "astro-og-canvas": "^0.12.0",
    "astro-robots": "^2.3.1",
    "canvaskit-wasm": "^0.41.1",
    "expressive-code-fullscreen": "^1.1.0",
    "mermaid": "^11.16.0",
    "sharp": "^0.35.2",
    "starlight-blog": "^0.27.0",
    "starlight-kbd": "^0.4.0",
    "starlight-links-validator": "^0.25.1",
    "starlight-llms-txt": "^0.10.0",
    "starlight-package-managers": "^0.12.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260628.1",
    "cspell": "^10.0.1",
    "knip": "^6.23.0",
    "markdownlint-cli2": "^0.22.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.9.3",
    "stylelint-use-logical-spec": "^5.0.1",
    "typescript": "^6.0.2",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.17.1"
}
