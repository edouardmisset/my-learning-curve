---
import { BASE_PATH } from '~/constants/links'
// oxlint-disable-next-line import/no-unassigned-import
import '~/styles/feed.css'
---

<div class="feed-shell">
  <header class="feed-header">
    <a href={`${BASE_PATH}/`} class="feed-brand">My Learning Curve</a>
    <nav class="feed-nav" aria-label="Main">
      <a href={`${BASE_PATH}/blog`}>Blog</a>
      <a href={`${BASE_PATH}/feeds`}>Feed</a>
      <a href={`${BASE_PATH}/learn`}>Learn</a>
    </nav>
  </header>

  <main class="feed-main">
    <slot />
  </main>
</div>
