---
import { getCollection } from 'astro:content'
import DocumentLayout from '~/components/DocumentLayout.astro'
import FeedLayout from '~/components/FeedLayout.astro'
import { FEEDS } from '~/config/feeds'
import { LINKS } from '~/constants/links'
import { getLatestFeedEntries } from '~/utils/feeds'

const feedsWithArticles = (
  await Promise.all(
    FEEDS.map(async feed => {
      const entries = getLatestFeedEntries(await getCollection(feed.collection))
      const latestEntry = entries[0]
      const latestArticleTime =
        (latestEntry
          ? (latestEntry.data.published ?? latestEntry.data.updated)?.getTime()
          : null) ?? 0

      return {
        feed,
        entriesCount: entries.length,
        latestArticleTime,
      }
    }),
  )
)
  .filter(item => item.entriesCount > 0)
  .sort(
    (left, right) =>
      right.latestArticleTime - left.latestArticleTime ||
      left.feed.title.localeCompare(right.feed.title),
  )
  .map(item => item.feed)
---

<DocumentLayout
  title="Feed | My Learning Curve"
  description="Discover live RSS feeds curated in My Learning Curve."
>
  <FeedLayout>
    <section class="feed-hero">
      <p class="feed-kicker">RSS Feeds</p>
      <h1>Feed</h1>
    </section>

    <section class="feed-grid" aria-label="Available feeds">
      {
        feedsWithArticles.map(feed => (
          <article class="feed-card">
            <p class="feed-kicker">Live Feed Loader</p>
            <h2>{feed.title}</h2>
            <p>{feed.description}</p>
            <div class="feed-card-links">
              <a class="feed-link" href={LINKS.feeds(feed.slug)}>
                View feed articles
              </a>
              <a
                class="feed-muted-link"
                href={feed.websiteUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Open website ↗
              </a>
            </div>
          </article>
        ))
      }
    </section>
  </FeedLayout>
</DocumentLayout>
