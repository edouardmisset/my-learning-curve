---
import { getCollection, render } from 'astro:content'
import DocumentLayout from '~/components/DocumentLayout.astro'
import FeedLayout from '~/components/FeedLayout.astro'
import { BASE_PATH, LINKS, WEBSITE_URL } from '~/constants/links'

export async function getStaticPaths(): Promise<any[]> {
  const skills = await getCollection('skills')
  return skills.map(skill => ({
    params: { slug: skill.id },
    props: { skill },
  }))
}

const { skill } = Astro.props
const { Content } = await render(skill)

const installCmd = `npx skills add ${WEBSITE_URL}/.well-known/agent-skills/${skill.id}`
---

<DocumentLayout
  title={`${skill.data.name} | Agent Skills | My Learning Curve`}
  description={skill.data.description}
>
  <FeedLayout>
    <article class="feed-article" style="animation: none;">
      <p class="feed-breadcrumb">
        <a href={LINKS.skills()}>Skills</a> /{' '}
        <span>{skill.data.name}</span>
      </p>

      <div
        style="display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem;"
      >
        <h1 style="margin: 0;">{skill.data.name}</h1>
        <span
          style="font-size: 0.8rem; font-weight: bold; text-transform: uppercase; color: var(--feed-accent-soft); padding: 0.2rem 0.6rem; border-radius: 9999px; background-color: var(--feed-surface-2); border: 1px solid var(--feed-border)"
        >
          {skill.data.type}
        </span>
      </div>

      <p
        style="font-size: 1.1rem; line-height: 1.6; color: var(--feed-muted); margin-bottom: 2rem;"
      >
        {skill.data.description}
      </p>

      <div
        style="background-color: var(--feed-surface-2); border: 1px solid var(--feed-border); border-radius: 1rem; padding: 1.5rem; margin-bottom: 2.5rem; display: flex; flex-direction: column; gap: 0.75rem;"
      >
        <h3 style="margin: 0; font-size: 1.1rem; color: var(--feed-text)">
          Install command
        </h3>
        <p style="margin: 0; font-size: 0.9rem; color: var(--feed-muted);">
          Run this in your terminal to install this skill with the CLI:
        </p>
        <div
          style="display: flex; align-items: center; justify-content: space-between; background-color: var(--feed-base); padding: 0.75rem 1rem; border-radius: 0.5rem; font-family: monospace; font-size: 0.85rem; border: 1px solid var(--feed-border); color: var(--feed-accent-soft); overflow-x: auto; white-space: nowrap;"
        >
          <span>{installCmd}</span>
        </div>
      </div>

      <div
        class="feed-content"
        style="line-height: 1.7; display: flex; flex-direction: column; gap: 1rem;"
      >
        <Content />
      </div>

      <div
        style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--feed-border); display: flex; gap: 1rem;"
      >
        <a class="feed-link" href={LINKS.skills()}> ← Back to skills </a>
        <a
          class="feed-muted-link"
          href={`${BASE_PATH}/.well-known/agent-skills/${skill.id}/SKILL.md`}
          target="_blank"
          rel="noopener noreferrer"
        >
          View raw SKILL.md ↗
        </a>
      </div>
    </article>
  </FeedLayout>
</DocumentLayout>

<style is:global>
  /* Base headings styles for skill content inside feed-content */
  .feed-content h1,
  .feed-content h2,
  .feed-content h3 {
    color: var(--feed-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }
  .feed-content h1 {
    font-size: 1.6rem;
  }
  .feed-content h2 {
    font-size: 1.35rem;
  }
  .feed-content h3 {
    font-size: 1.15rem;
  }
  .feed-content ul,
  .feed-content ol {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
    padding-left: 0;
  }
  .feed-content li {
    margin-bottom: 0.5rem;
    color: var(--feed-muted);
  }
  .feed-content strong {
    color: var(--feed-text);
  }
</style>
