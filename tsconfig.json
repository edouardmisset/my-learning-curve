{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "{src,scripts}/**/*.{ts,mjs,mts,js}"
  ],
  "exclude": [
    "dist",
    "./src/content/**/tsconfig.json",
    "node_modules",
    "**/node_modules/**"
  ],
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "skipLibCheck": true,
    "paths": {
      "~/*": ["./src/*"]
    }
  }
}
